{#
  _base.njk
  ---------
  The main layout shell. Every page file extends this.

  Files that use this layout should start with:
    {% extends "components/_base.njk" %}
    {% set title = "Page Title" %}
    {% block content %}
      ... your page HTML here ...
    {% endblock %}

  The content block is plain HTML — no special syntax required inside it.
  All macros and components are optional; import only what a page needs.

  Variables (all optional — defaults shown below):
    title      — appended to <title> as "Steven Raden - {title}".
                 Leave unset for just "Steven Raden".
    rootPath   — base path for nav links. Default: "../" (correct for work/ pages).
                 index.njk should set this to "./"
    bodyClass  — class on <body>. Default: "project"
    backUrl    — if set, renders a back button in the header pointing to this URL.
                 Leave unset (the default) and no button appears. Useful for old
                 portfolio pages that previously used a custom back-link pattern.

  Example with back button (useful for older pages):
    {% set backUrl = "../index.html" %}

  Example for root-level index page:
    {% set rootPath = "./" %}
    {% set bodyClass = "home" %}

  Adding page-specific <head> content (extra scripts, stylesheets, etc.):
    {% block head %}
      <script src="..."></script>
    {% endblock %}
#}
<!DOCTYPE html>
<html>
<head>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,400i,500,700" rel="stylesheet">
    <link rel="stylesheet" href="{{ rootPath | default('../') }}style/main.css">
    <title>Steven Raden{% if title %} - {{ title }}{% endif %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {% block head %}{% endblock %}
</head>
<body class="{{ bodyClass | default('project') }}">
    {#
      block body — override this entire block on pages with a custom full-bleed layout
      (e.g. the homepage). Project pages leave this block as-is and use {% block content %}.
    #}
    {% block body %}
    {#
      Default body — project page two-column layout.
      Set {% set projectSymbol = "✦" %} in the child template to use a
      custom symbol on the panel. Defaults to ◆.
      Homepage overrides this entire block with its own layout.
    #}
    <div class="project-layout">

        <aside class="project-panel" aria-hidden="true">
            <div class="project-panel__markers">
                <span class="project-panel__triangle">▽</span>
                <span class="project-panel__rule"></span>
                <div class="project-panel__dots">
                    <span class="project-panel__dot"></span>
                    <span class="project-panel__dot"></span>
                    <span class="project-panel__dot"></span>
                    <span class="project-panel__dot"></span>
                    <span class="project-panel__dot"></span>
                    <span class="project-panel__dot"></span>
                    <span class="project-panel__dot"></span>
                    <span class="project-panel__dot"></span>
                    <span class="project-panel__dot"></span>
                </div>
            </div>
            <div class="project-panel__symbol">{{ projectSymbol | default("◆") }}</div>
            <span class="project-panel__slash">//////</span>
        </aside>

        <div class="project-body">
            <nav class="project-nav">
                <a href="{{ backUrl if backUrl else (rootPath | default('../') + 'index.html') }}" class="project-nav__back">← Work</a>
                <div class="project-nav__links">
                    <a href="https://photo.sraden.com/" target="_blank" rel="noopener">Photography</a>
                    <a href="{{ rootPath | default('../') }}assets/Steven Raden Resume - 2026.pdf" target="_blank">Résumé</a>
                </div>
            </nav>
            {% block content %}{% endblock %}

            <div class="project-cta">
                <p class="project-cta__label">// More Work</p>
                <a class="project-cta__link" href="{{ rootPath | default('../') }}index.html#work">View all projects</a>
            </div>
        </div>

    </div>
    {% endblock %}
</body>
</html>
