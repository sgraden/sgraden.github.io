{% extends "components/_base.njk" %}

{% set rootPath = "./" %}
{% set bodyClass = "home" %}

{% block body %}
<div class="home-layout">

    {# ── Left cyan panel ─────────────────────────────────────────────────── #}
    <aside class="home-panel" aria-hidden="true">
        <span class="home-panel__year">2015 — Today</span>

        <div class="home-panel__markers">
            <span class="home-panel__triangle">▽</span>
            <span class="home-panel__rule"></span>
            <div class="home-panel__dots">
                <span class="home-panel__dot"></span>
                <span class="home-panel__dot"></span>
                <span class="home-panel__dot"></span>
                <span class="home-panel__dot"></span>
                <span class="home-panel__dot"></span>
                <span class="home-panel__dot"></span>
                <span class="home-panel__dot"></span>
                <span class="home-panel__dot"></span>
                <span class="home-panel__dot"></span>
            </div>
        </div>

        <div class="home-panel__monogram">SR</div>
        <span class="home-panel__slash">//////</span>
    </aside>

    {# ── Main content ────────────────────────────────────────────────────── #}
    <main class="home-content">

        <nav class="home-nav">
            <a href="#work">Work</a>
            <a href="https://photo.sraden.com/" target="_blank" rel="noopener">Photography</a>
            <a href="./assets/Steven Raden Resume - 2026.pdf" target="_blank">Résumé</a>
        </nav>

        <div class="home-hero">
            <p class="home-label">// Product Designer</p>
            <h1>Steven<br>Raden</h1>
            <p class="home-bio">Senior product designer at Cloudflare. Security platforms, developer tools, design systems.</p>
        </div>

        {# ── Case Studies — priority pieces with substantial written work ── #}
        <div class="home-work" id="work">
            <p class="home-work__heading">Case Studies</p>
            <ul class="home-work__list">

                <li class="work-item work-item--featured">
                    <a href="./work/cloudflare-appsec-overview.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">AppSec Overview</span>
                        <span class="work-item__company">Cloudflare</span>
                        <span class="work-item__year">2024</span>
                    </a>
                </li>

                <li class="work-item work-item--featured">
                    <a href="./work/vpc.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">IBM Cloud VPC</span>
                        <span class="work-item__company">IBM</span>
                        <span class="work-item__year">2020</span>
                    </a>
                </li>

                <li class="work-item work-item--featured">
                    <a href="./work/tactile-toolkit.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">Tactile Toolkit</span>
                        <span class="work-item__company">IBM</span>
                        <span class="work-item__year">2019</span>
                    </a>
                </li>

            </ul>
        </div>

        {# ── Selected Work — full project list ─────────────────────────── #}
        <div class="home-work home-work--secondary-list">
            <p class="home-work__heading">Selected Work</p>
            <ul class="home-work__list">

                {# Featured — strongest / most recent #}
                <li class="work-item work-item--featured">
                    <a href="./work/cloudflare-appsec-overview.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">AppSec Overview</span>
                        <span class="work-item__company">Cloudflare</span>
                        <span class="work-item__year">2024</span>
                    </a>
                </li>

                <li class="work-item work-item--featured">
                    <a href="./work/cloudflare-email-routing.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">Email Routing</span>
                        <span class="work-item__company">Cloudflare</span>
                        <span class="work-item__year">2023</span>
                    </a>
                </li>

                {# Secondary — solid work but lower priority in the list #}
                <li class="work-item work-item--secondary">
                    <a href="./work/cloudflare-workers-unbound.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">Workers Unbound</span>
                        <span class="work-item__company">Cloudflare</span>
                        <span class="work-item__year">2022</span>
                    </a>
                </li>

                <li class="work-item work-item--secondary">
                    <a href="./work/cis.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">IBM Cloud Internet Services</span>
                        <span class="work-item__company">IBM</span>
                        <span class="work-item__year">2021</span>
                    </a>
                </li>

                <li class="work-item work-item--secondary">
                    <a href="./work/vpc.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">IBM Cloud VPC</span>
                        <span class="work-item__company">IBM</span>
                        <span class="work-item__year">2020</span>
                    </a>
                </li>

                <li class="work-item work-item--secondary">
                    <a href="./work/tactile-toolkit.html">
                        <span class="work-item__dot"></span>
                        <span class="work-item__title">Tactile Toolkit</span>
                        <span class="work-item__company">IBM</span>
                        <span class="work-item__year">2019</span>
                    </a>
                </li>

            </ul>
        </div>

        {# ── Recognition ───────────────────────────────────────────────── #}
        <div class="home-recognition">
            <p class="home-work__heading">Recognition</p>
            <ul class="home-recognition__list">

                <li class="home-recognition__item">
                    <span class="home-recognition__title">Superhero Award</span>
                    <p class="home-recognition__desc">
                        Company-wide recognition for going above and beyond at IBM. Nominated by manager <a href="https://www.linkedin.com/in/tytyner/" target="_blank" rel="noopener">Ty Tyner</a> for my work on the <a href="./work/vpc.html" target="_blank" rel="noopener">IBM Cloud VPC</a> project — a complex enterprise infrastructure product serving thousands of customers.
                    </p>
                </li>

                <li class="home-recognition__item">
                    <span class="home-recognition__title">Patterns Bootcamp Design Lead &amp; PixelHusky Hackathon</span>
                    <p class="home-recognition__desc">
                        Led and mentored emerging designers — from design students to early-career UX practitioners — through structured bootcamps and competitive hackathons. Guided participants through real UX design challenges with a focus on user-centered methods and delivering results under pressure.
                    </p>
                </li>

            </ul>
        </div>

    </main>

    {# ── Right decorative strip (hidden on mobile) ───────────────────────── #}
    <aside class="home-strip" aria-hidden="true">
        <span class="home-strip__dot">·</span>
        <span class="home-strip__dot">·</span>
        <span class="home-strip__dot">·</span>
        <span class="home-strip__spacer"></span>
        <span class="home-strip__cross">×</span>
        <span class="home-strip__rule"></span>
        <span class="home-strip__rule home-strip__rule--faint"></span>
    </aside>

</div>
{% endblock %}
