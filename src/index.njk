<script>
(function () {
  var track = document.getElementById('testimonialsTrack');
  var dotsContainer = document.getElementById('testimonialsDots');
  var prevBtn = document.getElementById('testimonialsPrev');
  var nextBtn = document.getElementById('testimonialsNext');
  var carousel = document.getElementById('testimonialsCarousel');
  var slides = track.querySelectorAll('.testimonial-slide');
  var current = 0;
  var timer = null;
  var resumeTimeout = null;
  var INTERVAL = 5000;      // ms between auto-advances
  var RESUME_DELAY = 1500;  // ms after hover-out before resuming

  // Lock carousel height to tallest slide so page doesn't jump on advance
  function lockHeight() {
    var max = 0;
    slides.forEach(function (s) {
      var h = s.offsetHeight;
      if (h > max) max = h;
    });
    if (max > 0) carousel.style.minHeight = max + 'px';
  }

  // Build dot indicators
  slides.forEach(function (_, i) {
    var dot = document.createElement('button');
    dot.className = 'testimonials-dot';
    dot.setAttribute('aria-label', 'Slide ' + (i + 1));
    dot.addEventListener('click', function () { goTo(i); scheduleResume(); });
    dotsContainer.appendChild(dot);
  });

  function updateDots() {
    dotsContainer.querySelectorAll('.testimonials-dot').forEach(function (d, i) {
      d.classList.toggle('is-active', i === current);
    });
  }

  function goTo(n) {
    current = ((n % slides.length) + slides.length) % slides.length;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    updateDots();
  }

  // Fully stop both the interval and any pending resume
  function stopAll() {
    clearInterval(timer);
    clearTimeout(resumeTimeout);
    timer = null;
    resumeTimeout = null;
  }

  // Start a fresh consistent interval
  function startTimer() {
    stopAll();
    timer = setInterval(function () { goTo(current + 1); }, INTERVAL);
  }

  // After a manual action (click/nav), wait a full INTERVAL before resuming
  function scheduleResume() {
    stopAll();
    resumeTimeout = setTimeout(startTimer, INTERVAL);
  }

  // After hover-out, wait RESUME_DELAY before resuming (grace period)
  function scheduleResumeAfterHover() {
    clearTimeout(resumeTimeout);
    resumeTimeout = setTimeout(startTimer, RESUME_DELAY);
  }

  prevBtn.addEventListener('click', function () { goTo(current - 1); scheduleResume(); });
  nextBtn.addEventListener('click', function () { goTo(current + 1); scheduleResume(); });

  // Pause while hovering; resume after grace period on leave
  carousel.addEventListener('mouseenter', stopAll);
  carousel.addEventListener('mouseleave', scheduleResumeAfterHover);

  lockHeight();
  window.addEventListener('resize', lockHeight);
  updateDots();
  startTimer();
}());
</script>
