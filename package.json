{
  "name": "sraden.com",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "reposity": "https://github.com/sgraden/sraden.com",
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "nunjucks-cli": "^1.0.0",
    "prettier": "^2.0.5",
    "sass": "^1.32.0"
  },
  "scripts": {
    "start": "npm run build && browser-sync start --server --files \"*.html, work/*.html, style/*.css\"",
    "build": "nunjucks '**/*.njk' --path src -o . --extension html",
    "watch": "npm-run-all --parallel watch:njk watch:sass watch:serve",
    "watch:njk": "nunjucks '**/*.njk' --path src -o . --extension html --watch",
    "watch:sass": "sass --watch scss/main.scss style/main.css",
    "watch:serve": "browser-sync start --server --files \"*.html, work/*.html, style/*.css\""
  },
  "author": "",
  "license": "ISC"
}
